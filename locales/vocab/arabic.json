        { "ar": "عَن", "tr": "ʿan", "en": "about / from", "ex_ar": "تَحَدَّثَ عَن سَفَرِه", "ex_en": "He talked about his travel." },
        { "ar": "لِ / لِـ", "tr": "li-", "en": "for / to (belonging / purpose)", "ex_ar": "هَذَا الكِتَاب لِي", "ex_en": "This book is for me." },
