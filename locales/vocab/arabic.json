    "greetings_and_basics": {
      "label": "Greetings & Basic Expressions / التحيات والتعبيرات الأساسية",
      "entries": [
        { "ar": "مَرْحَبًا", "tr": "marḥaban", "en": "Hello / Welcome", "ex_ar": "مَرْحَبًا، كَيْفَ حَالُكَ؟", "ex_en": "Hello, how are you?" },
        { "ar": "أَهْلاً وَسَهْلاً", "tr": "ahlan wa-sahlan", "en": "Welcome (warm greeting)", "ex_ar": "أَهْلاً وَسَهْلاً بِكَ فِي بَيْتِنَا!", "ex_en": "Welcome to our home!" },
        { "ar": "السَّلَامُ عَلَيْكُم", "tr": "as-salāmu ʿalaykum", "en": "Peace be upon you (Islamic greeting)", "ex_ar": "السَّلَامُ عَلَيْكُم، كَيْفَ أَنْتُم؟", "ex_en": "Peace be upon you, how are you all?" },
        { "ar": "وَعَلَيْكُمُ السَّلَام", "tr": "wa-ʿalaykum as-salām", "en": "And peace be upon you (response)", "ex_ar": "وَعَلَيْكُمُ السَّلَام وَرَحْمَةُ اللَّه", "ex_en": "And upon you peace and God's mercy." },
        { "ar": "مَعَ السَّلَامَة", "tr": "maʿa s-salāma", "en": "Goodbye (stay safe)", "ex_ar": "مَعَ السَّلَامَة، إِلَى اللِّقَاء", "ex_en": "Goodbye, see you soon." },
        { "ar": "إِلَى اللِّقَاء", "tr": "ilā l-liqāʾ", "en": "See you soon", "ex_ar": "إِلَى اللِّقَاء غَدًا إِنْ شَاءَ اللَّه", "ex_en": "See you tomorrow, God willing." },
        { "ar": "صَبَاحُ الخَيْر", "tr": "ṣabāḥu l-khayr", "en": "Good morning", "ex_ar": "صَبَاحُ الخَيْر يَا أُسْتَاذ", "ex_en": "Good morning, teacher." },
        { "ar": "مَسَاءُ الخَيْر", "tr": "masāʾu l-khayr", "en": "Good evening", "ex_ar": "مَسَاءُ الخَيْر، كَيْفَ كَانَ يَوْمُكَ؟", "ex_en": "Good evening, how was your day?" },
        { "ar": "تَصْبَحُ عَلَى خَيْر", "tr": "tiṣbaḥu ʿalā khayr", "en": "Good night", "ex_ar": "تَصْبَحُ عَلَى خَيْر وَأَنْعِم", "ex_en": "Good night and sweet dreams." },
        { "ar": "مِنْ فَضْلِكَ", "tr": "min faḍlika", "en": "Please (to a male)", "ex_ar": "مِنْ فَضْلِكَ، أَعْطِنِي الكِتَاب", "ex_en": "Please give me the book." },
        { "ar": "شُكْرًا", "tr": "shukran", "en": "Thank you", "ex_ar": "شُكْرًا جَزِيلاً عَلَى مُسَاعَدَتِكَ", "ex_en": "Thank you very much for your help." },
        { "ar": "عَفْوًا", "tr": "ʿafwan", "en": "You're welcome / Excuse me", "ex_ar": "عَفْوًا، لَا شُكْرَ عَلَى وَاجِب", "ex_en": "You're welcome, it's no trouble." },
        { "ar": "آسِف", "tr": "āsif", "en": "Sorry (male)", "ex_ar": "آسِف، لَمْ أَفْهَم", "ex_en": "Sorry, I didn't understand." },
        { "ar": "لَا أَفْهَم", "tr": "lā afham", "en": "I don't understand", "ex_ar": "لَا أَفْهَم، هَلْ يُمْكِنُكَ الشَّرْح مَرَّة أُخْرَى؟", "ex_en": "I don't understand, can you explain again?" },
        { "ar": "هَلْ تَتَكَلَّمُ الإِنْجِلِيزِيَّة؟", "tr": "hal tatakallamu l-injilīziyya?", "en": "Do you speak English?", "ex_ar": "هَلْ تَتَكَلَّمُ الإِنْجِلِيزِيَّة؟ لَا أَتَكَلَّمُ العَرَبِيَّة جَيِّدًا", "ex_en": "Do you speak English? I don't speak Arabic well." }
      ]
    },
