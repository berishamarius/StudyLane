        { "ar": "دَرَسَ", "tr": "darasa", "en": "to study (he studied)", "ex_ar": "دَرَسَ اللُّغَة العَرَبِيَّة فِي القَاهِرَة", "ex_en": "He studied Arabic in Cairo." },
