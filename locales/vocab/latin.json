        { "la": "carpe diem", "en": "seize the day", "ex_la": "Carpe diem, quam minimum credula postero. (Horatius)", "ex_en": "Seize the day, trusting as little as possible in tomorrow." },
        { "la": "tempus fugit", "en": "time flies", "ex_la": "Sed fugit interea, fugit irreparabile tempus. (Vergilius)", "ex_en": "But meanwhile time flees, irretrievable time flees." },
        { "la": "amor vincit omnia", "en": "love conquers all", "ex_la": "Amor vincit omnia, et nos cedamus amori. (Vergilius)", "ex_en": "Love conquers all things, and let us yield to love." },
