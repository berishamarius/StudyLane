        { "la": "lego, legere, legi, lectum", "en": "to read / gather / choose", "ex_la": "Discipulus librum legit.", "ex_en": "The student reads the book." },
        { "la": "scribo, scribere, scripsi, scriptum", "en": "to write", "ex_la": "Cicero multas epistulas scripsit.", "ex_en": "Cicero wrote many letters." },
        { "la": "amo, amare, amavi, amatum", "en": "to love / like", "ex_la": "Romani patriam suam amabant.", "ex_en": "The Romans loved their homeland." },
        { "la": "habeo, habere, habui, habitum", "en": "to have / hold", "ex_la": "Quid habes in manu?", "ex_en": "What do you have in your hand?" },
        { "la": "peto, petere, petivi, petitum", "en": "to seek / ask / attack", "ex_la": "Sapientiam semper petamus.", "ex_en": "Let us always seek wisdom." },
        { "la": "possum, posse, potui", "en": "to be able to / can", "ex_la": "Fortis esse potes si velis.", "ex_en": "You can be strong if you wish." },
