        { "la": "dico, dicere, dixi, dictum", "en": "to say / speak", "ex_la": "Veritas semper dicenda est.", "ex_en": "The truth must always be spoken." },
        { "la": "facio, facere, feci, factum", "en": "to make / do", "ex_la": "Noli multa simul facere.", "ex_en": "Do not do many things at once." },
        { "la": "video, videre, vidi, visum", "en": "to see", "ex_la": "Quid vides, amice?", "ex_en": "What do you see, friend?" },
