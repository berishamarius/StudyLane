        { "la": "malus, -a, -um", "en": "bad / evil", "ex_la": "Mala consilia principem perdunt.", "ex_en": "Bad plans ruin a leader." },
        { "la": "pulcher, pulchra, pulchrum", "en": "beautiful / handsome", "ex_la": "Roma urbs pulcherrima est.", "ex_en": "Rome is the most beautiful city." },
        { "la": "longus, -a, -um", "en": "long", "ex_la": "Iter longum erat.", "ex_en": "The journey was long." },
        { "la": "brevis, breve", "en": "short / brief", "ex_la": "Vita brevis, ars longa.", "ex_en": "Life is short, art is long." },
        { "la": "altus, -a, -um", "en": "high / deep", "ex_la": "Mons altissimus regionem dominat.", "ex_en": "The very high mountain dominates the region." },
        { "la": "novus, -a, -um", "en": "new", "ex_la": "Nova via per vallem ducit.", "ex_en": "A new road leads through the valley." },
        { "la": "antiquus, -a, -um / vetus, veteris", "en": "ancient / old", "ex_la": "Antiqui Romani multa nobis tradiderunt.", "ex_en": "The ancient Romans passed many things down to us." },
        { "la": "fortis, forte", "en": "strong / brave", "ex_la": "Miles fortis pro patria pugnat.", "ex_en": "The brave soldier fights for the homeland." },
        { "la": "sapiens, sapientis", "en": "wise", "ex_la": "Sapiens homo multa tacet.", "ex_en": "A wise person keeps silent about many things." },
        { "la": "laetus, -a, -um", "en": "happy / joyful", "ex_la": "Discipuli laeti scholam relinquunt.", "ex_en": "The happy students leave the school." },
        { "la": "tristis, triste", "en": "sad", "ex_la": "Tristis puer in angulo sedet.", "ex_en": "The sad boy sits in the corner." },
        { "la": "liber, libera, liberum", "en": "free", "ex_la": "Homo liber suam vitam regit.", "ex_en": "A free person governs his own life." }
