    "greetings_and_basics": {
      "label": "Greetings & Basic Expressions / Salutationes",
      "entries": [
        { "la": "Salve! (sg.) / Salvete! (pl.)", "en": "Hello! / Greetings!", "ex_la": "Salve, Marce! Ut vales?", "ex_en": "Hello, Marcus! How are you?" },
        { "la": "Vale! (sg.) / Valete! (pl.)", "en": "Farewell! / Goodbye!", "ex_la": "Vale, amice! Cras te videbo.", "ex_en": "Farewell, friend! I will see you tomorrow." },
        { "la": "Ave! / Avete!", "en": "Hail! / Greetings! (formal/imperial)", "ex_la": "Ave, Caesar!", "ex_en": "Hail, Caesar!" },
        { "la": "Bene vale", "en": "Farewell well / All the best", "ex_la": "Bene vale et memento mei.", "ex_en": "Farewell and remember me." },
        { "la": "Gratias tibi ago", "en": "I give thanks to you / Thank you", "ex_la": "Gratias tibi ago pro auxilio tuo.", "ex_en": "Thank you for your help." },
        { "la": "Quaeso / Amabo te", "en": "Please / I beg you", "ex_la": "Quaeso, da mihi librum.", "ex_en": "Please give me the book." },
        { "la": "Ignosce mihi", "en": "Pardon me / Forgive me", "ex_la": "Ignosce mihi, non intellexi.", "ex_en": "Forgive me, I did not understand." },
        { "la": "Non intellego", "en": "I do not understand", "ex_la": "Non intellego hanc regulam.", "ex_en": "I do not understand this rule." },
        { "la": "Quid est nomen tibi?", "en": "What is your name?", "ex_la": "Quid est nomen tibi, amice?", "ex_en": "What is your name, friend?" },
        { "la": "Nomen mihi est …", "en": "My name is …", "ex_la": "Nomen mihi est Marcus.", "ex_en": "My name is Marcus." },
        { "la": "Ita / Ita est", "en": "Yes / It is so", "ex_la": "Ita, haec vera sunt.", "ex_en": "Yes, these things are true." },
        { "la": "Non / Minime", "en": "No / Not at all", "ex_la": "Non, hoc non verum est.", "ex_en": "No, this is not true." },
        { "la": "Bene / Optime", "en": "Well / Excellent", "ex_la": "Optime! Hoc facere potes.", "ex_en": "Excellent! You can do this." },
        { "la": "Recte / Vere", "en": "Correctly / Truly", "ex_la": "Recte dicis, mi amice.", "ex_en": "You speak correctly, my friend." }
      ]
    },
