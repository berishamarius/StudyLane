{
  "name": "tasklane",
  "version": "1.0.0",
  "description": "TaskLane – Digitaler Arbeitsplaner für Mitarbeiter & Azubis",
  "main": "main.js",
  "author": "KX KroniX Tech",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --publish never",
    "build:web": "node scripts/build-web.js",
    "generate:icons": "node scripts/generate-icons.js",
    "android": "npm run build:web && npx cap sync android && npx cap open android",
    "cap:sync": "npm run build:web && npx cap sync",
    "cap:copy": "npm run build:web && npx cap copy"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1",
    "sharp": "^0.33.0",
    "to-ico": "^1.1.5",
    "png2icons": "^2.0.1"
  },
  "dependencies": {
    "@capacitor/core": "^6.0.0",
    "@capacitor/android": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/keyboard": "^6.0.0"
  },
  "build": {
    "appId": "com.kronix.tasklane",
    "productName": "TaskLane",
    "copyright": "Copyright 2026 KX KroniX Tech",
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TaskLane"
    },
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "files": [
      "**/*",
      "!node_modules/.cache",
      "!dist/**",
      "!**/*.map"
    ]
  }
}
